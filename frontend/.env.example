VITE_AEROBIM_API_BASE_URL=
# Leave empty in `npm run dev` so the Vite proxy handles /v1 + Authorization.
# Set AEROBIM_API_BEARER_TOKEN in the shell (NOT VITE_*) when starting Vite:
#   set AEROBIM_API_BEARER_TOKEN=dev-local-token-change-me
#   npm run dev
#
# Only set VITE_AEROBIM_API_BEARER_TOKEN for legacy direct-to-backend demos —
# that value is PUBLIC in the JS bundle. Prefer a reverse proxy in production.
# VITE_AEROBIM_API_BASE_URL=http://localhost:8080
# VITE_AEROBIM_API_BEARER_TOKEN=dev-local-token-change-me
