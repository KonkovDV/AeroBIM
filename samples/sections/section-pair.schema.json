{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aerobim.dev/schemas/section-pair-1.0.0.json",
  "title": "AeroBIM normalized PD/RD section evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_id",
    "project_id",
    "stage",
    "discipline",
    "section_code",
    "revision",
    "values"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "document_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "stage": { "enum": ["PD", "ПД", "RD", "РД"] },
    "discipline": { "type": "string", "minLength": 1 },
    "section_code": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "basis": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "document_id": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "minLength": 1 }
      }
    },
    "values": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2000,
      "items": { "$ref": "#/$defs/value" }
    }
  },
  "$defs": {
    "value": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "value"],
      "properties": {
        "key": { "type": "string", "minLength": 1, "maxLength": 256 },
        "value": { "type": ["string", "number", "boolean"] },
        "unit": { "type": "string", "minLength": 1 },
        "target_ref": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string", "minLength": 1 },
        "required_in_rd": { "type": "boolean", "default": true },
        "tolerance_si": { "type": "number", "minimum": 0 },
        "problem_zone": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "sheet_id": { "type": ["string", "null"] },
            "page_number": { "type": ["integer", "null"], "minimum": 1 },
            "x": { "type": ["number", "null"] },
            "y": { "type": ["number", "null"] },
            "width": { "type": ["number", "null"], "minimum": 0 },
            "height": { "type": ["number", "null"], "minimum": 0 },
            "element_guid": { "type": ["string", "null"] }
          }
        }
      }
    }
  }
}
