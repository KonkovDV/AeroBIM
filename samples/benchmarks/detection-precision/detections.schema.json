{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aerobim.dev/schemas/detections-1.0.0.json",
  "title": "AeroBIM frozen detection run",
  "type": "object",
  "required": ["schema_version", "run_id", "cases"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "findings"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "discipline": {
            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Optional discipline code for per_discipline metrics"
          },
          "findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/finding" }
          }
        }
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["finding_class", "rule_id"],
      "properties": {
        "finding_class": { "type": "string", "minLength": 1 },
        "rule_id": { "type": "string", "minLength": 1 },
        "target_ref": { "type": "string", "minLength": 1 },
        "element_guid": { "type": "string", "minLength": 1 },
        "match_key": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["target_ref"] },
        { "required": ["element_guid"] },
        { "required": ["match_key"] }
      ]
    }
  }
}
