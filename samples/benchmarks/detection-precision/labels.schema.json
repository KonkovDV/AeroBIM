{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aerobim.dev/schemas/detection-labels-1.0.0.json",
  "title": "AeroBIM detection labels",
  "type": "object",
  "required": ["schema_version", "dataset_id", "dataset_status", "cases"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "dataset_id": { "type": "string", "minLength": 1 },
    "dataset_status": { "enum": ["synthetic", "draft", "adjudicated"] },
    "scope_reference": { "type": "string", "minLength": 1 },
    "held_out_split": {
      "type": "boolean",
      "description": "True when metrics are measured on a held-out / test split (required for product publishable claims)"
    },
    "evaluation_split": {
      "type": "string",
      "description": "Optional split label; held_out|holdout|test also satisfies the held-out gate"
    },
    "adjudication": {
      "type": "object",
      "required": ["method", "completed_at", "adjudicators"],
      "properties": {
        "method": { "enum": ["consensus", "majority-with-resolution", "dual_independent"] },
        "completed_at": { "type": "string", "format": "date-time" },
        "adjudicators": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "role": { "type": "string" }
            }
          }
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["case_id", "expected_findings"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "discipline": {
            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Optional discipline code (ar|ov|kzh|…); used for per_discipline metrics"
          },
          "expected_findings": {
            "type": "array",
            "items": { "$ref": "#/$defs/labeledFinding" }
          }
        }
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["finding_class", "rule_id"],
      "properties": {
        "finding_class": { "type": "string", "minLength": 1 },
        "rule_id": { "type": "string", "minLength": 1 },
        "target_ref": { "type": "string", "minLength": 1 },
        "element_guid": { "type": "string", "minLength": 1 },
        "match_key": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["target_ref"] },
        { "required": ["element_guid"] },
        { "required": ["match_key"] }
      ]
    },
    "labeledFinding": {
      "allOf": [
        { "$ref": "#/$defs/finding" },
        {
          "type": "object",
          "properties": {
            "adjudication_status": {
              "enum": ["confirmed", "excluded", "unresolved"]
            }
          }
        }
      ]
    }
  }
}
