{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aerobim.dev/schemas/norm-rule-pack-1.0.0.json",
  "title": "AeroBIM norm rule pack",
  "description": "Machine-readable acceptance criteria. When status is approved or customer_approved, a full approval object plus document metadata and pack_hash are mandatory. approval_ref alone is never sufficient. Synthetic/fixture packs must carry claim_labels and cannot claim customer_approved.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "version",
    "title",
    "typology",
    "disciplines",
    "status",
    "rules"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "pack_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
    "version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "title": { "type": "string", "minLength": 1, "maxLength": 256 },
    "typology": { "type": "string", "minLength": 1, "maxLength": 128 },
    "jurisdiction": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 128,
      "description": "Jurisdiction label (e.g. RF); required when status is approved/customer_approved"
    },
    "edition": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 128,
      "description": "Optional pack edition string; distinct from per-rule norm_edition / approval.document_edition"
    },
    "disciplines": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 64 }
    },
    "status": {
      "enum": ["synthetic-template", "synthetic", "draft", "approved", "customer_approved", "retired"]
    },
    "claim_labels": {
      "type": "array",
      "description": "Honesty labels. Fixture packs must include synthetic and/or fixture; those labels forbid customer_approved status.",
      "items": {
        "type": "string",
        "enum": [
          "synthetic",
          "fixture",
          "draft",
          "not-customer-evidence",
          "template",
          "customer-evidence"
        ]
      },
      "uniqueItems": true
    },
    "pack_hash": {
      "type": ["string", "null"],
      "pattern": "^[a-fA-F0-9]{64}$",
      "description": "SHA-256 of canonical rule payload; required for approved/customer_approved sign-off"
    },
    "source_hash": {
      "type": ["string", "null"],
      "pattern": "^[a-fA-F0-9]{64}$",
      "description": "Alias of pack_hash when present; mismatch with recomputed hash blocks sign-off"
    },
    "approval": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "approved_by",
        "approval_date",
        "approval_status",
        "document_title",
        "document_edition",
        "effective_date",
        "scope_reference"
      ],
      "properties": {
        "approved_by": { "type": "string", "minLength": 1 },
        "approval_date": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 approval timestamp (timezone required at load time)"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time",
          "description": "Deprecated alias for approval_date; loader accepts either"
        },
        "approval_status": {
          "enum": ["approved", "customer_approved"]
        },
        "document_title": { "type": "string", "minLength": 1, "maxLength": 512 },
        "document_edition": { "type": "string", "minLength": 1, "maxLength": 128 },
        "effective_date": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Norm/document effective date (ISO date or datetime)"
        },
        "scope_reference": { "type": "string", "minLength": 1 }
      }
    },
    "approval_ref": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 512,
      "description": "Jury-facing approval id. Never sufficient alone for customer_approved/approved — full approval object required."
    },
    "customer_action_required": { "type": "string" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "enum": ["approved", "customer_approved"] }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["approval", "jurisdiction"],
        "properties": {
          "approval": {
            "type": "object",
            "required": [
              "approved_by",
              "approval_date",
              "approval_status",
              "document_title",
              "document_edition",
              "effective_date",
              "scope_reference"
            ]
          },
          "jurisdiction": { "type": "string", "minLength": 1 },
          "pack_hash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
        },
        "anyOf": [
          { "required": ["pack_hash"] },
          { "required": ["source_hash"] }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "claim_labels": {
            "contains": { "enum": ["synthetic", "fixture", "template", "not-customer-evidence"] }
          }
        },
        "required": ["claim_labels"]
      },
      "then": {
        "not": {
          "properties": {
            "status": { "enum": ["approved", "customer_approved"] }
          },
          "required": ["status"]
        }
      }
    }
  ],
  "$defs": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "scope", "operator", "property_name"],
      "properties": {
        "rule_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
        "scope": {
          "enum": ["ifc-property", "ifc-quantity", "drawing-annotation"]
        },
        "ifc_entity": { "type": "string", "minLength": 1 },
        "target_ref": { "type": "string", "minLength": 1 },
        "property_set": { "type": "string", "minLength": 1 },
        "property_name": { "type": "string", "minLength": 1 },
        "operator": { "enum": ["eq", "=", "equals", "gte", ">=", "lte", "<=", "exists"] },
        "expected_value": { "type": ["string", "number", "boolean", "null"] },
        "unit": { "type": "string", "minLength": 1 },
        "evidence_text": { "type": "string" },
        "instructions": { "type": "string" },
        "norm_source": { "type": ["string", "null"], "maxLength": 256 },
        "norm_edition": { "type": ["string", "null"], "maxLength": 128 },
        "norm_clause": {
          "type": ["string", "null"],
          "maxLength": 128,
          "description": "Clause reference; required on rules when pack status is approved/customer_approved"
        },
        "clause": {
          "type": ["string", "null"],
          "maxLength": 128,
          "description": "Alias for norm_clause"
        },
        "approval_status": {
          "type": ["string", "null"],
          "enum": ["synthetic", "draft", "customer_approved", null]
        },
        "approval_ref": { "type": ["string", "null"], "maxLength": 512 }
      }
    }
  }
}
