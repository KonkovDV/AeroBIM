# AeroBIM — Environment Configuration
# Copy to .env and adjust values for your environment.

AEROBIM_APP_NAME=aerobim-backend
AEROBIM_ENV=development
AEROBIM_HOST=127.0.0.1
AEROBIM_PORT=8080
AEROBIM_STORAGE_DIR=var/reports
AEROBIM_DEBUG=false

# Comma-separated allowed CORS origins.
# If empty, defaults to localhost:3000,5173 only when AEROBIM_DEBUG=true; nothing otherwise.
# AEROBIM_CORS_ORIGINS=https://app.example.com,https://review.example.com

# Optional static API token guard for all /v1 endpoints.
# Required when AEROBIM_ENV is not development/test (fail-closed).
# When using Settings.from_env() without a token, set this OR
# AEROBIM_ALLOW_ANONYMOUS_DEV=true (dev/test only).
# AEROBIM_API_BEARER_TOKEN=replace-with-long-random-token
# AEROBIM_ALLOW_ANONYMOUS_DEV=false

# When true, hard clashes (or failed clash capability) set summary.passed=False.
# AEROBIM_CLASH_AFFECTS_PASS=false

# When true, missing/skipped clash capability is FAILED (no green pass without clash engine).
# Samolet TechLab pilot profile: set BOTH require_clash and clash_affects_pass.
# AEROBIM_REQUIRE_CLASH=false
#
# --- Samolet TechLab pilot profile (recommended for Task 07 packages) ---
# AEROBIM_PRIORITY_PROFILE=samolet
# AEROBIM_REQUIRE_CLASH=true
# AEROBIM_CLASH_AFFECTS_PASS=true
# AEROBIM_REQUIRE_BSI_SCHEMA=true
# AEROBIM_CROSS_DOC_SEVERITY=error
# AEROBIM_ENFORCE_OBJECT_ACL=true
# Install clash extra: pip install '.[clash]'
# Still NOT: MEP system-aware clash, CDE BCF import proof, customer >90% accuracy.

# Maximum accepted IFC file size in bytes (default 256 MiB, aligned with bSI Validation Service).
# AEROBIM_MAX_IFC_BYTES=268435456

# OpenCDE BCF API 3.0 push (optional). Access token from Foundation OAuth2 / hub.
# AEROBIM_BCF_API_BASE_URL=https://hub.example.com/opencde
# AEROBIM_BCF_API_TOKEN=replace-with-hub-access-token
# AEROBIM_BCF_API_PROJECT_ID=F445F4F2-4D02-4B2A-B612-5E456BEF9137
# AEROBIM_BCF_API_VERSION=3.0

# OIDC JWT validation (optional; accepted alongside static bearer). Requires enterprise extra.
# AEROBIM_OIDC_ISSUER=https://idp.example.com/realms/aerobim
# AEROBIM_OIDC_AUDIENCE=aerobim-api
# AEROBIM_OIDC_JWKS_URL=https://idp.example.com/realms/aerobim/protocol/openid-connect/certs

# Optional Redis URL for durable async analyze jobs (enterprise extra).
# AEROBIM_REDIS_URL=redis://127.0.0.1:6379/0

# Optional buildingSMART IFC Validation Service (remote) or local schema-pack certificate.
# AEROBIM_BSI_VALIDATION_URL=https://dev.validate.buildingsmart.org
# AEROBIM_BSI_API_TOKEN=replace-with-bsi-token
# AEROBIM_BSI_LOCAL_CERT=true

# Remark language for TemplateRemarkGenerator: ru (default) | en
# AEROBIM_REMARK_LOCALE=ru

# Severity emitted for cross-document contradictions detected in multi-source analysis.
# "warning" (default) — contradictions are surfaced but do not set passed=False.
# "error"             — all cross-document contradictions are blocking (delivery gate).
# "info"              — informational only, always non-blocking.
# AEROBIM_CROSS_DOC_SEVERITY=warning

# Default norm/rule pack (customer acceptance-criteria) used when a request/manifest
# does not list norm_rule_pack_paths. Storage-relative path (inside the storage jail).
# If set but the file is missing at analysis time, capabilities.norm_rule_packs fails
# closed (FAILED) instead of a silent skip. Leave unset to skip norm packs by default.
# AEROBIM_NORM_RULE_PACK=uploads/customer/residential-ar-pack.json

# Legal-gated native DWG via ODA/Teigha stub (STUB-ODA-CAD-001). Default off.
# AEROBIM_ODA_CAD_ENABLED=false

# Opt-in system-aware MEP clash (still requires scope memo + IfcSystem). MEP-CLASH-001.
# AEROBIM_MEP_SYSTEM_CLASH_ENABLED=false
# AEROBIM_MEP_SCOPE_MEMO_REF=

# Hybrid drawing analyzer (detector priors + OCR). Vision extra: pip install '.[vision]'.
# Never flips cv_human_level to OK. AEROBIM_HYBRID_DRAWING_ENABLED=true

# Optional IFC parse cache directory for SLA ≤30 min / комплект (NFR).
# AEROBIM_IFC_PARSE_CACHE_DIR=var/ifc-cache

# Optional Postgres summary index for enterprise storage rollout.
# AEROBIM_DB_URL=postgresql+asyncpg://user:password@localhost:5432/aerobim

# Optional retention policy for persisted reports; leave unset for unlimited retention.
# AEROBIM_REPORT_TTL_DAYS=30

# Optional S3 / MinIO object-store settings.
# AEROBIM_S3_BUCKET=aerobim-artifacts
# AEROBIM_S3_ENDPOINT_URL=http://127.0.0.1:9000
# AEROBIM_S3_REGION=us-east-1
# AEROBIM_S3_ACCESS_KEY_ID=minioadmin
# AEROBIM_S3_SECRET_ACCESS_KEY=minioadmin
# AEROBIM_S3_PREFIX=aerobim
