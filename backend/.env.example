# AeroBIM — Environment Configuration
# Copy to .env and adjust values for your environment.

AEROBIM_APP_NAME=aerobim-backend
AEROBIM_ENV=development
AEROBIM_HOST=127.0.0.1
AEROBIM_PORT=8080
AEROBIM_STORAGE_DIR=var/reports
AEROBIM_DEBUG=true

# Comma-separated allowed CORS origins.
# If empty, defaults to localhost:3000,5173 in debug mode; nothing in production.
# AEROBIM_CORS_ORIGINS=https://app.example.com,https://review.example.com
