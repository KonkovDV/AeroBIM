# AeroBIM — Environment Configuration
# Copy to .env and adjust values for your environment.

AEROBIM_APP_NAME=aerobim-backend
AEROBIM_ENV=development
AEROBIM_HOST=127.0.0.1
AEROBIM_PORT=8080
AEROBIM_STORAGE_DIR=var/reports
AEROBIM_DEBUG=true

# Comma-separated allowed CORS origins.
# If empty, defaults to localhost:3000,5173 in debug mode; nothing in production.
# AEROBIM_CORS_ORIGINS=https://app.example.com,https://review.example.com

# Optional static API token guard for all /v1 endpoints.
# When set, clients must send: Authorization: Bearer <token>
# AEROBIM_API_BEARER_TOKEN=replace-with-long-random-token

# Severity emitted for cross-document contradictions detected in multi-source analysis.
# "warning" (default) — contradictions are surfaced but do not set passed=False.
# "error"             — all cross-document contradictions are blocking (delivery gate).
# "info"              — informational only, always non-blocking.
# AEROBIM_CROSS_DOC_SEVERITY=warning

# Optional Postgres summary index for enterprise storage rollout.
# AEROBIM_DB_URL=postgresql+asyncpg://user:password@localhost:5432/aerobim

# Optional retention policy for persisted reports; leave unset for unlimited retention.
# AEROBIM_REPORT_TTL_DAYS=30

# Optional S3 / MinIO object-store settings.
# AEROBIM_S3_BUCKET=aerobim-artifacts
# AEROBIM_S3_ENDPOINT_URL=http://127.0.0.1:9000
# AEROBIM_S3_REGION=us-east-1
# AEROBIM_S3_ACCESS_KEY_ID=minioadmin
# AEROBIM_S3_SECRET_ACCESS_KEY=minioadmin
# AEROBIM_S3_PREFIX=aerobim
